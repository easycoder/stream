{
    "#doc": "eclecity.net landing page",
    "#element": "div",
    "@id": "page",
    "font-family": "Georgia, serif",
    "max-width": "36em",
    "margin": "6em auto",
    "padding": "2em",
    "color": "#333",
    "text-align": "center",
    "#": ["$Mark", "$Tagline"],

    "$Mark": {
        "#element": "h1",
        "#content": "eclecity",
        "font-weight": "300",
        "letter-spacing": "0.15em",
        "font-size": "3em",
        "margin": "0 0 0.3em 0",
        "color": "#222"
    },

    "$Tagline": {
        "#element": "p",
        "#content": "A quiet corner of the web.",
        "color": "#888",
        "font-style": "italic",
        "margin": "0"
    }
}
