{
  "$OpenBtn": {
    "#element": "button",
    "@id": "se-open",
    "#content": "Open",
    "padding": "4px 12px",
    "cursor": "pointer"
  },
  "$TabBar": {
    "#element": "div",
    "@id": "se-tabbar",
    "display": "flex",
    "gap": "2px",
    "overflow-x": "auto",
    "min-width": "0"
  },
  "$PlusBtn": {
    "#element": "img",
    "@id": "se-plusbtn",
    "@src": "https://allspeak.ai/icon/plus.png",
    "width": "20px",
    "height": "20px",
    "cursor": "pointer",
    "padding": "4px",
    "flex-shrink": "0"
  },
  "$TabGroup": {
    "#element": "div",
    "@id": "se-tabgroup",
    "display": "flex",
    "flex": "1",
    "align-items": "center",
    "min-width": "0",
    "#": ["$TabBar", "$PlusBtn"]
  },
  "$BlocksBtn": {
    "#element": "button",
    "@id": "se-blocksbtn",
    "#content": "Blocks",
    "padding": "4px 12px",
    "cursor": "pointer",
    "flex-shrink": "0"
  },
  "$FindBtn": {
    "#element": "button",
    "@id": "se-findbtn",
    "#content": "Find",
    "padding": "4px 12px",
    "cursor": "pointer",
    "flex-shrink": "0"
  },
  "$StatusSpan": {
    "#element": "span",
    "@id": "se-status",
    "color": "lightgreen",
    "font-size": "0.85em",
    "padding": "0 8px",
    "white-space": "nowrap",
    "min-width": "6em",
    "text-align": "right"
  },
  "$Logo": {
    "#element": "img",
    "@id": "se-logo",
    "@src": "https://allspeak.ai/icon/duckthink.png",
    "width": "28px",
    "height": "28px",
    "border-radius": "6px",
    "flex-shrink": "0"
  },
  "$TopBar": {
    "#element": "div",
    "@id": "se-topbar",
    "display": "flex",
    "align-items": "center",
    "background": "#2d2d2d",
    "padding": "4px",
    "gap": "4px",
    "#": ["$Logo", "$OpenBtn", "$TabGroup", "$StatusSpan", "$BlocksBtn", "$FindBtn"]
  },
  "$ContentEditor": {
    "#element": "textarea",
    "@id": "se-textarea",
    "width": "100%",
    "height": "100%"
  },
  "$ContentDiv": {
    "#element": "div",
    "width": "100%",
    "height": "100%",
    "#": ["$ContentEditor"]
  },
  "$EditorArea": {
    "#element": "div",
    "@id": "se-editor-area",
    "height": "calc(100vh - 40px)",
    "#": ["$ContentDiv"]
  },
  "$BlocksTitle": {
    "#element": "span",
    "@id": "se-blocks-title",
    "flex": "1",
    "color": "#ddd"
  },
  "$BlocksPrev": {
    "#element": "button",
    "@id": "se-blocks-prev",
    "#content": "▲",
    "padding": "2px 10px",
    "cursor": "pointer"
  },
  "$BlocksNext": {
    "#element": "button",
    "@id": "se-blocks-next",
    "#content": "▼",
    "padding": "2px 10px",
    "cursor": "pointer"
  },
  "$BlocksBadge": {
    "#element": "span",
    "@id": "se-blocks-badge",
    "padding": "2px 8px",
    "border-radius": "3px",
    "font-size": "0.85em",
    "background": "#555",
    "color": "white",
    "min-width": "10em",
    "text-align": "center"
  },
  "$BlocksVerifyBtn": {
    "#element": "button",
    "@id": "se-blocks-verify",
    "#content": "Mark verified",
    "padding": "2px 10px",
    "cursor": "pointer"
  },
  "$BlocksToolbar": {
    "#element": "div",
    "@id": "se-blocks-toolbar",
    "display": "flex",
    "align-items": "center",
    "gap": "8px",
    "padding": "4px 8px",
    "background": "#3a3a3a",
    "color": "#ddd",
    "font-size": "0.9em",
    "flex-shrink": "0",
    "#": ["$BlocksTitle", "$BlocksPrev", "$BlocksNext", "$BlocksBadge", "$BlocksVerifyBtn"]
  },
  "$BlocksToc": {
    "#element": "div",
    "@id": "se-blocks-toc",
    "width": "200px",
    "height": "100%",
    "overflow-y": "auto",
    "background": "#262626",
    "color": "#ccc",
    "font-family": "system-ui, sans-serif",
    "font-size": "12px",
    "padding": "4px 0",
    "border-right": "1px solid #444",
    "flex-shrink": "0",
    "box-sizing": "border-box"
  },
  "$BlocksCodePane": {
    "#element": "textarea",
    "@id": "se-blocks-code",
    "flex": "0 0 60%",
    "height": "100%",
    "font-family": "monospace",
    "font-size": "13px",
    "border": "none",
    "padding": "8px",
    "box-sizing": "border-box",
    "resize": "none",
    "outline": "none"
  },
  "$BlocksDivider": {
    "#element": "div",
    "@id": "se-blocks-divider",
    "width": "6px",
    "height": "100%",
    "cursor": "col-resize",
    "background": "#bbb",
    "flex-shrink": "0"
  },
  "$BlocksDocPane": {
    "#element": "textarea",
    "@id": "se-blocks-doc",
    "flex": "1 1 0",
    "height": "100%",
    "font-family": "Georgia, serif",
    "font-size": "14px",
    "border": "none",
    "padding": "8px",
    "box-sizing": "border-box",
    "resize": "none",
    "outline": "none",
    "background": "#f8f8f5"
  },
  "$BlocksSplit": {
    "#element": "div",
    "@id": "se-blocks-split",
    "display": "flex",
    "flex": "1",
    "overflow": "hidden",
    "#": ["$BlocksToc", "$BlocksCodePane", "$BlocksDivider", "$BlocksDocPane"]
  },
  "$BlocksArea": {
    "#element": "div",
    "@id": "se-blocks-area",
    "display": "none",
    "flex-direction": "column",
    "height": "calc(100vh - 40px)",
    "#": ["$BlocksToolbar", "$BlocksSplit"]
  },
  "$Scroller": {
    "#element": "div",
    "@id": "se-scroller",
    "flex": "1",
    "overflow-y": "auto",
    "margin-bottom": "0.5em",
    "min-height": "100px"
  },
  "$CloseBtn": {
    "#element": "button",
    "@id": "se-closebtn",
    "#content": "Close"
  },
  "$FileListing": {
    "#element": "div",
    "position": "absolute",
    "width": "50%",
    "max-height": "70%",
    "background": "white",
    "padding": "1em",
    "top": "50%",
    "left": "50%",
    "transform": "translateX(-50%) translateY(-50%)",
    "display": "flex",
    "flex-direction": "column",
    "border-radius": "4px",
    "#": ["$Scroller", "$CloseBtn"]
  },
  "$Overlay": {
    "#element": "div",
    "@id": "se-overlay",
    "display": "none",
    "position": "fixed",
    "top": "0",
    "left": "0",
    "width": "100vw",
    "height": "100vh",
    "background": "rgba(0,0,0,0.5)",
    "z-index": "100",
    "#": ["$FileListing"]
  },
  "#": ["$TopBar", "$EditorArea", "$BlocksArea", "$Overlay"]
}
